---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DashboardSidebar from '@/components/dashboard/DashboardSidebar.astro';
import EditProfileForm from '@/components/dashboard/EditProfileForm';
import { useTranslations } from '@/i18n/translations';

const lang = Astro.locals.lang;
const tr = useTranslations(lang);
const user = Astro.locals.user;

if (!user) {
  return Astro.redirect(`/login?redirect=/mi-cuenta`);
}
---

<BaseLayout
  title={tr('auth.dashboard.title')}
>
  <div class="w-full max-w-[1280px] mx-auto px-5 md:px-8 flex flex-col md:flex-row min-h-[calc(100vh-4rem)] py-8 gap-8">
    <DashboardSidebar lang={lang} userName={user.name} />
    <div class="flex-1">
      <EditProfileForm client:load lang={lang} />
    </div>
  </div>
</BaseLayout>
