---
import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthLayout from '@/components/ui/AuthLayout.astro';
import LoginForm from '@/components/auth/LoginForm';
import { useTranslations } from '@/i18n/translations';

const lang = Astro.locals.lang;
const tr = useTranslations(lang);

if (Astro.locals.user) {
  return Astro.redirect('/mi-cuenta');
}
---

<BaseLayout
  title={tr('auth.login.heading')}
  isAuthenticated={false}
>
  <AuthLayout
    eyebrow={tr('auth.login.eyebrow')}
    title={tr('auth.login.heading')}
    subtitle={tr('auth.login.subtitle')}
    heroImage="/images/auth/login-hero.jpg"
    heroEyebrow={tr('auth.hero.eyebrow')}
    heroTitle={tr('auth.hero.title')}
    heroSlogan={tr('auth.hero.slogan')}
  >
    <LoginForm client:load lang={lang} />
  </AuthLayout>
</BaseLayout>
