---
export const prerender = false;

import BaseLayout from '@/layouts/BaseLayout.astro';
import AuthLayout from '@/components/ui/AuthLayout.astro';
import SetPasswordForm from '@/components/auth/SetPasswordForm';
import LoginRightPanel from '@/components/auth/LoginRightPanel.astro';
import { fetchLoginPage } from '@/lib/nodehive';
import { useTranslations } from '@/i18n/translations';

const lang = Astro.locals.lang;
const tr = useTranslations(lang);

const uid = Astro.url.searchParams.get('uid');
const timestamp = Astro.url.searchParams.get('timestamp');
const hash = Astro.url.searchParams.get('hash');

if (!uid || !timestamp || !hash) {
  return Astro.redirect('/login');
}

let loginPage = null;
try {
  loginPage = await fetchLoginPage(lang);
} catch (e) {
  console.error('[NodeHive] Failed to fetch login page:', e);
}
---

<BaseLayout title={tr('auth.setPassword.heading')}>
  <AuthLayout
    eyebrow={tr('auth.setPassword.eyebrow')}
    title={tr('auth.setPassword.heading')}
    subtitle={tr('auth.setPassword.subtitle')}
    heroImage="/images/auth/login-hero.jpg"
  >
    <SetPasswordForm client:load lang={lang} uid={uid} timestamp={timestamp} hash={hash} />
    <LoginRightPanel slot="right" right={loginPage?.right} lang={lang} />
  </AuthLayout>
</BaseLayout>
