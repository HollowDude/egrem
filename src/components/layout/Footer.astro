---
/**
 * Footer.astro — Pie de página global de EGREM.
 *
 * Estructura (fiel a la maqueta):
 *  - Borde rojo superior (3px)
 *  - 4 columnas: Identidad+Redes | Explorar | Información | Contacto
 *  - Barra inferior con copyright y "volver arriba"
 *
 * Fondo: #1b1b1b | Texto: #c2b0ae | Headings: #CC0000 (rojo)
 * Social buttons: borde #603e39, hover dorado.
 *
 * NodeHive: datos de contacto desde paragraph "_fragment_footer_contact"
 */

import type { NhFooterFragment } from '@/lib/nodehive';
import { resolveFileUrl } from '@/lib/nodehive';
import EgremLogo from '@/components/ui/EgremLogo.astro';
import Button from '@/components/ui/Button.astro';
import NodeHiveEntity from '@/components/nodehive/NodeHiveEntity.astro';
import type { Lang } from '@/i18n';
import { useTranslations } from '@/i18n/translations';

interface Props {
  nhFooter?: NhFooterFragment | null;
  lang?: Lang;
}
const { nhFooter, lang = 'es' } = Astro.props;
const tr = useTranslations(lang);

const currentYear = new Date().getFullYear();
const derechos =
  nhFooter?.derechos ||
  `© ${currentYear} EGREM — ${lang === 'en' ? 'Recording and Music Publishing Company of Cuba. All rights reserved.' : 'Empresa de Grabaciones y Ediciones Musicales. Todos los derechos reservados.'}`;
const tagline = nhFooter?.title || tr('footer.tagline');
const contacto = nhFooter?.contacto;
const logoUrl = nhFooter?.logo?.url ? resolveFileUrl(nhFooter.logo.url) : null;
const redes = nhFooter?.redes ?? [];

const navExplorar = [
  { label: tr('nav.store'), href: '/tienda' },
  { label: tr('nav.news'), href: '/actualidad' },
  { label: tr('nav.catalog'), href: '/catalogo' },
  { label: tr('nav.events'), href: '/eventos' },
];

const navInfo = [
  { label: tr('nav.about'), href: '/sobre-nosotros' },
  { label: tr('footer.privacy'), href: '/politica-privacidad' },
  { label: tr('footer.terms'), href: '/terminos-condiciones' },
  { label: tr('footer.faq'), href: '/preguntas-frecuentes' },
];
---

<footer
  style="background-color: var(--color-footer-bg); color: var(--color-footer-text); border-top: 3px solid var(--color-egrem-red);"
>
  <NodeHiveEntity
    entityType="nodehive_fragment"
    bundle="footer"
    id={nhFooter?.id}
    internalId={nhFooter?.drupalInternalFid}
    lang={lang}
    tag="div"
    class=""
    editLabel="Editar Footer"
    editField="field_title"
  >
    {/* ── Cuerpo principal ── */}
    <div class="container-site" style="padding-top: 3rem; padding-bottom: 0;">
      <div class="footer-grid gap-8">
        {/* ── Col 1: Identidad + Redes ── */}
        <div class="flex flex-col gap-4">
          {/* Logo */}
          <EgremLogo variant="light" width={120} class="self-start" src={logoUrl} />

          {/* Tagline en Ravellin dorado */}
          <a href="/" class="no-underline">
            <p class="font-script text-egrem-gold leading-snug m-0" style="font-size: 1.15rem">
              {tagline}
            </p>
          </a>

          {/* Redes sociales */}
          <div class="mt-2">
            <p class="footer-col-heading" style="margin-bottom: 12px;">
              {tr('footer.follow')}
            </p>
            <div class="flex items-center gap-3">
              {
                redes.length > 0 ? (
                  redes.map((red) => {
                    const url = red.link?.uri ?? '#';
                    const name = red.link?.title ?? 'Red social';
                    const u = url.toLowerCase();
                    return (
                      <a
                        href={url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="social-btn no-underline"
                        aria-label={name}
                      >
                        {u.includes('facebook') ? (
                          <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                          >
                            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                          </svg>
                        ) : u.includes('instagram') ? (
                          <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                          >
                            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                          </svg>
                        ) : u.includes('youtube') ? (
                          <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                          >
                            <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z" />
                          </svg>
                        ) : u.includes('twitter') || u.includes('x.com') ? (
                          <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                          >
                            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
                          </svg>
                        ) : u.includes('tiktok') ? (
                          <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                          >
                            <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z" />
                          </svg>
                        ) : u.includes('spotify') ? (
                          <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                          >
                            <path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z" />
                          </svg>
                        ) : (
                          <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            aria-hidden="true"
                          >
                            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" />
                          </svg>
                        )}
                      </a>
                    );
                  })
                ) : (
                  /* Fallback: hardcoded social icons */
                  <>
                    <a
                      href="https://facebook.com"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="social-btn no-underline"
                      aria-label="Facebook"
                    >
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z" />
                      </svg>
                    </a>
                    <a
                      href="https://instagram.com"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="social-btn no-underline"
                      aria-label="Instagram"
                    >
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                      </svg>
                    </a>
                    <a
                      href="https://youtube.com"
                      target="_blank"
                      rel="noopener noreferrer"
                      class="social-btn no-underline"
                      aria-label="YouTube"
                    >
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M23.495 6.205a3.007 3.007 0 0 0-2.088-2.088c-1.87-.501-9.396-.501-9.396-.501s-7.507-.01-9.396.501A3.007 3.007 0 0 0 .527 6.205a31.247 31.247 0 0 0-.522 5.805 31.247 31.247 0 0 0 .522 5.783 3.007 3.007 0 0 0 2.088 2.088c1.868.502 9.396.502 9.396.502s7.506 0 9.396-.502a3.007 3.007 0 0 0 2.088-2.088 31.247 31.247 0 0 0 .5-5.783 31.247 31.247 0 0 0-.5-5.805zM9.609 15.601V8.408l6.264 3.602z" />
                      </svg>
                    </a>
                  </>
                )
              }
            </div>
          </div>
        </div>

        {/* ── Col 2: Explorar ── */}
        <div>
          <h3 class="footer-col-heading">{tr('footer.explore')}</h3>
          <nav>
            {
              navExplorar.map((item) => (
                <a href={item.href} class="footer-link block">
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>

        {/* ── Col 3: Información de la empresa ── */}
        <div>
          <h3 class="footer-col-heading">{tr('footer.info')}</h3>
          <nav>
            {
              navInfo.map((item) => (
                <a href={item.href} class="footer-link block">
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>

        {/* ── Col 4: Contacto ── */}
        {
          /*
        NodeHive: paragraph bundle "_fragment_footer_contact"
        <NodeHiveEntity entityType="nodehive_fragment" bundle="_fragment_footer_contact" lang={lang}>
      */
        }
        <div class="flex flex-col gap-3">
          <h3 class="footer-col-heading">{tr('footer.contact')}</h3>

          <div class="flex items-start gap-2" style="margin-bottom: 0.25rem;">
            <span
              class="icon shrink-0 mt-0.5"
              style="font-size:1.1rem; color: var(--color-egrem-red);">location_on</span
            >
            <p
              class="font-display text-[0.8rem] m-0 leading-relaxed"
              style="color: var(--color-footer-text);"
            >
              {
                contacto?.direccion ||
                  'Calle 3ra No. 1008 e/ 10 y 12, Miramar, Playa, La Habana, Cuba'
              }
            </p>
          </div>

          <a
            href={`mailto:${contacto?.correo || 'info@egrem.co.cu'}`}
            class="footer-link flex items-center gap-2"
          >
            <span class="icon shrink-0" style="font-size:1.1rem; color: var(--color-egrem-red);"
              >mail</span
            >
            {contacto?.correo || 'info@egrem.co.cu'}
          </a>

          <a
            href={`tel:${(contacto?.telefono || '+53 7 204 9822').replace(/\s/g, '')}`}
            class="footer-link flex items-center gap-2"
          >
            <span class="icon shrink-0" style="font-size:1.1rem; color: var(--color-egrem-red);"
              >call</span
            >
            {contacto?.telefono || '+53 7 204 9822 / +53 7 204 9823'}
          </a>

          <Button
            variant="primary"
            size="sm"
            href={contacto?.boton?.link?.uri || '/contacto'}
            target="_blank"
            rel="noopener noreferrer"
            class="self-start mt-1"
          >
            <span class="icon" style="font-size:0.95rem">mail</span>
            {contacto?.boton?.title || tr('nav.contact')}
          </Button>
        </div>
      </div>
    </div>

    {/* ── Divider ── */}
    <div class="container-site">
      <hr
        style="border: none; border-top: 1px solid rgba(255,255,255,0.08); margin: 32px 0 24px;"
        aria-hidden="true"
      />
    </div>

    {/* ── Barra inferior ── */}
    <div
      class="container-site pb-8 flex flex-col md:flex-row items-center justify-between"
      style="gap: 16px;"
    >
      <p
        class="m-0 text-center md:text-left"
        style="color: #c2b0ae; font-size: 13px; font-family: var(--font-sans); line-height: 1.5;"
      >
        {derechos}
      </p>
      <button
        type="button"
        onclick="window.scrollTo({top:0,behavior:'smooth'})"
        class="footer-back-top flex items-center gap-1.5 font-display font-bold text-[0.68rem] uppercase tracking-widest cursor-pointer bg-transparent rounded px-3 py-1.5"
        aria-label={tr('footer.back_top')}
      >
        {tr('footer.back_top')}
      </button>
    </div>
  </NodeHiveEntity>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.4fr 0.9fr 1.1fr 1.4fr;
    }
  }

  .footer-col-heading {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 1rem 0;
  }

  .footer-link {
    font-family: var(--font-display);
    font-size: 0.875rem;
    color: var(--color-footer-text);
    text-decoration: none;
    padding: 0.25rem 0;
    transition: color 0.2s ease;
  }

  .footer-link:hover {
    color: var(--color-egrem-gold);
    text-decoration: none;
  }

  .footer-back-top {
    color: var(--color-footer-text);
    border: 1px solid rgba(255, 255, 255, 0.15);
    transition: all 0.2s ease;
  }

  .footer-back-top:hover {
    border-color: var(--color-egrem-gold);
    color: var(--color-egrem-gold);
  }
</style>
