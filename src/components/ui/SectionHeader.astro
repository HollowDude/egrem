---
/**
 * SectionHeader.astro
 * Cabecera de sección — fiel a la maqueta.
 *
 * Patrón visual: título uppercase con border-bottom grueso + enlace "Ver todo" a la derecha.
 *
 * Temas:
 *  - light → texto negro (fondos blancos/claros)
 *  - dark  → texto blanco (fondos oscuros)
 */
interface Props {
  title: string;
  /** Color del borde inferior de acento. Por defecto: rojo. */
  accent?: 'red' | 'gold';
  /** Texto del enlace "ver todo / ver más". Omitir si no se necesita. */
  linkText?: string;
  linkHref?: string;
  theme?: 'light' | 'dark';
  class?: string;
  /** data-nodehive-field para el título */
  nhField?: string;
}

const {
  title,
  accent = 'red',
  linkText,
  linkHref = '#',
  theme = 'light',
  class: className,
  nhField,
} = Astro.props;

const isDark = theme === 'dark';
const borderColor = accent === 'gold' ? 'border-egrem-gold' : 'border-egrem-red';
---

<div
  class:list={[
    'flex items-end justify-between mb-6',
    className,
  ]}
>
  <h2
    class:list={[
      'section-title border-b-4 pb-2 m-0 inline-block',
      borderColor,
      isDark ? 'text-white' : 'text-egrem-black',
    ]}
    data-nodehive-field={nhField}
  >
    {title}
  </h2>

  {linkText && (
    <a
      href={linkHref}
      class:list={[
        'font-display font-bold text-sm uppercase tracking-widest no-underline hover:underline transition-colors shrink-0 ml-6 mb-2',
        isDark
          ? 'text-egrem-gold hover:text-white'
          : 'text-egrem-red hover:underline',
      ]}
    >
      {linkText}
    </a>
  )}
</div>
