---
/**
 * Button.astro — Botón reutilizable de la marca EGREM.
 *
 * Variantes:
 *  - primary      → Rojo sólido (CTA principal)
 *  - secondary    → Borde dorado, texto dorado (fondos oscuros/hero)
 *  - ghost        → Contorno negro/oscuro (sobre fondos claros)
 *  - gold         → Dorado sólido
 *  - outline-red  → Contorno rojo (sobre fondos claros)
 *
 * Tamaños: sm | md | lg | xl
 */
import { buttonClasses, type ButtonSize, type ButtonVariant } from '@/lib/ui/buttonClasses';

interface Props {
  variant?: ButtonVariant;
  size?: ButtonSize;
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  class?: string;
  disabled?: boolean;
  [key: string]: unknown;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  type = 'button',
  class: className,
  disabled,
  ...rest
} = Astro.props;

const base = buttonClasses(variant, size, className);

---

{href ? (
  <a href={href} class={base} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class={base} disabled={disabled} {...rest}>
    <slot />
  </button>
)}
