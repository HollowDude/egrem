---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  heroImage: string;
}

const {
  eyebrow,
  title,
  subtitle,
  heroImage,
} = Astro.props;

const hasRightSlot = Astro.slots.has('right');
---

<section class="w-full flex min-h-[calc(100vh-4rem)]">
  <div class="w-full lg:w-1/2 flex items-center justify-center px-6 md:px-8 py-12 bg-white">
    <div class="w-full max-w-md">
      <div class="mb-8">
        <p
          class="font-display font-bold text-[11px] uppercase tracking-widest mb-2"
          style="color: var(--color-text-secondary);"
        >
          {eyebrow}
        </p>
        <h1
          class="font-display font-bold text-[clamp(28px,4vw,38px)] uppercase leading-tight border-l-4 border-brand-primary pl-4 m-0"
          style="color: var(--color-egrem-black);"
        >
          {title}
        </h1>
        <p
          class="font-sans text-sm mt-3 leading-relaxed"
          style="color: var(--color-text-secondary);"
        >
          {subtitle}
        </p>
      </div>

      <slot />

    </div>
  </div>

  <div class="hidden lg:flex w-1/2 relative overflow-hidden flex-col justify-end">
    {hasRightSlot ? (
      <slot name="right" />
    ) : (
      <div
        class="absolute inset-0 bg-cover bg-center"
        style={`background-image: url('${heroImage}');`}
      />
    )}
  </div>
</section>
