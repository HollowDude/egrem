---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  heroImage: string;
  heroEyebrow?: string;
  heroTitle?: string;
  heroSlogan?: string;
}

const {
  eyebrow,
  title,
  subtitle,
  heroImage,
  heroEyebrow = 'EGREM · Desde 1964',
  heroTitle = 'La casa de la<br>música cubana',
  heroSlogan = 'al mundo entero.',
} = Astro.props;
---

<section class="w-full flex min-h-[calc(100vh-4rem)]">
  <div class="w-full lg:w-1/2 flex items-center justify-center px-6 md:px-8 py-12 bg-white">
    <div class="w-full max-w-md">
      <div class="mb-8">
        <p
          class="font-display font-bold text-[11px] uppercase tracking-widest mb-2"
          style="color: var(--color-text-secondary);"
        >
          {eyebrow}
        </p>
        <h1
          class="font-display font-bold text-[clamp(28px,4vw,38px)] uppercase leading-tight border-l-4 border-brand-primary pl-4 m-0"
          style="color: var(--color-egrem-black);"
        >
          {title}
        </h1>
        <p
          class="font-sans text-sm mt-3 leading-relaxed"
          style="color: var(--color-text-secondary);"
        >
          {subtitle}
        </p>
      </div>

      <slot />

    </div>
  </div>

  <div class="hidden lg:flex w-1/2 relative overflow-hidden flex-col justify-end">
    <div
      class="absolute inset-0 bg-cover bg-center"
      style={`background-image: url('${heroImage}');`}
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent" />
    <div class="relative z-10 p-10 pb-12">
      <p
        class="font-display font-bold text-[11px] uppercase tracking-[0.15em] text-white/60 mb-2"
      >
        {heroEyebrow}
      </p>
      <h2
        class="font-display font-bold text-[clamp(24px,3vw,34px)] uppercase leading-tight text-white m-0"
        set:html={heroTitle}
      >
      </h2>
      <p
        class="font-script text-[22px] mt-1"
        style="color: var(--color-egrem-gold);"
      >
        {heroSlogan}
      </p>
    </div>
  </div>
</section>
