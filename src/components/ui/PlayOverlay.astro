---
/**
 * PlayOverlay.astro — Botón de play circular rojo.
 *
 * Modos:
 *  - always  → siempre visible (videos)
 *  - hover   → solo visible al hover del grupo padre (álbumes)
 *
 * Requiere que el padre tenga class="group" para el modo hover.
 */
interface Props {
  mode?: 'always' | 'hover';
  /** Icono Material Symbols. Default: play_circle (filled) */
  icon?: string;
  class?: string;
}

const { mode = 'always', icon = 'play_arrow', class: className } = Astro.props;

const containerClass =
  mode === 'hover'
    ? 'absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-200'
    : 'absolute inset-0 flex items-center justify-center';

const bgStyle = mode === 'hover' ? 'background: rgba(0,0,0,0.4);' : '';
---

<div class={containerClass} style={bgStyle} aria-hidden="true">
  <div class:list={['play-overlay', className]}>
    <span class="icon text-white" style="font-size: 1.8rem; font-variation-settings: 'FILL' 1;">
      {icon}
    </span>
  </div>
</div>
