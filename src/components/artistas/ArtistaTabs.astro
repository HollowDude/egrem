---
interface Tab {
  id: string;
  label: string;
  icon: string;
}

interface Props {
  tabs: Tab[];
}

const { tabs } = Astro.props;
---

<nav class="flex border-b border-egrem-gray/20 mb-8 overflow-x-auto" aria-label="Artist tabs">
  {tabs.map((tab) => (
    <button
      type="button"
      data-artista-tab={tab.id}
      class="flex items-center gap-2 px-6 py-4 font-display font-bold text-sm uppercase tracking-wider transition-all duration-200 border-b-2 border-transparent hover:text-egrem-red hover:border-egrem-red cursor-pointer bg-transparent whitespace-nowrap text-egrem-gray data-[active=true]:text-egrem-red data-[active=true]:border-egrem-red"
      data-active={tab.id === tabs[0].id}
    >
      <span style="font-family: 'Material Symbols Outlined'; font-size: 18px;">
        {tab.icon}
      </span>
      {tab.label}
    </button>
  ))}
</nav>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('[data-artista-tab]');
  const panels = document.querySelectorAll<HTMLElement>('[data-artista-tab-content]');

  function activateTab(id: string) {
    tabs.forEach((btn) => btn.dataset.active = btn.dataset.artistaTab === id ? 'true' : 'false');
    panels.forEach((panel) => {
      panel.hidden = panel.dataset.artistaTabContent !== id;
    });
    history.replaceState(null, '', `#${id}`);
  }

  tabs.forEach((btn) => {
    btn.addEventListener('click', () => activateTab(btn.dataset.artistaTab!));
  });

  const hash = location.hash.replace('#', '');
  if (hash && document.querySelector(`[data-artista-tab="${hash}"]`)) {
    activateTab(hash);
  }
</script>
