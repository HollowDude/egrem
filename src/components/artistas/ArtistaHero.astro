---
import type { NhArtistaDetail } from '@/lib/nodehive';
import NodeHiveEntity from '@/components/nodehive/NodeHiveEntity.astro';
interface Props {
  artista: NhArtistaDetail;
}

const { artista } = Astro.props;
const lang = Astro.locals.lang;
---

<NodeHiveEntity
  entityType="node"
  bundle="artista"
  id={artista.id}
  internalId={artista.nid}
  lang={lang}
  tag="section"
  class="relative h-[480px] md:h-[560px] w-full overflow-hidden bg-egrem-dark"
  editLabel="Editar Artista"
  editField="title"
>
  {artista.image?.url && (
    <div class="absolute inset-0">
      <img
        src={artista.image.url}
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
      />
    </div>
  )}
  <div class="absolute inset-0 bg-gradient-to-t from-black/88 via-black/45 to-black/10" />
  <div class="absolute bottom-0 left-0 w-full pb-12 md:pb-16 container-site">
    <div class="flex flex-col gap-4 items-start">
      <div class="flex gap-2">
        <span class="bg-egrem-red text-white px-3 py-1 font-display font-bold text-[12px] uppercase tracking-widest rounded">
          Son Cubano
        </span>
        {artista.agencia && (
          <span class="bg-egrem-gold text-white px-3 py-1 font-display font-bold text-[12px] uppercase tracking-widest rounded">
            {artista.agencia.name}
          </span>
        )}
      </div>
      <h1 class="font-display font-bold text-[clamp(2.5rem,8vw,5rem)] leading-none uppercase text-white drop-shadow-2xl m-0" data-nodehive-field="title">
        {artista.name}
      </h1>
      <p class="font-script text-[24px] md:text-[28px] text-egrem-gold drop-shadow-md m-0">
        {artista.summary}
      </p>
    </div>
  </div>
</NodeHiveEntity>
