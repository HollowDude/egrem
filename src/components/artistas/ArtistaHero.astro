---
import type { NhArtistaDetail } from '@/lib/nodehive';
import Badge from '@/components/ui/Badge.astro';
import NodeHiveEntity from '@/components/nodehive/NodeHiveEntity.astro';
interface Props {
  artista: NhArtistaDetail;
}

const { artista } = Astro.props;
const lang = Astro.locals.lang;
---

<NodeHiveEntity
  entityType="node"
  bundle="artista"
  id={artista.id}
  internalId={artista.nid}
  lang={lang}
  tag="section"
  class="bg-egrem-dark section-py border-b border-egrem-gray/20 text-center relative overflow-hidden"
  editLabel="Editar Artista"
  editField="title"
>
  {artista.image?.url && (
    <div class="absolute inset-0 opacity-30">
      <img
        src={artista.image.url}
        alt=""
        class="w-full h-full object-cover"
        loading="eager"
        decoding="async"
      />
    </div>
  )}
  <div class="absolute inset-0 bg-gradient-to-t from-egrem-dark via-transparent to-egrem-dark/50" />
  <div class="container-site relative z-10">
    {artista.agencia && (
      <Badge variant="white" class="mb-4 inline-block">{artista.agencia.name}</Badge>
    )}
    <h1 class="text-h1 text-white uppercase mb-3" data-nodehive-field="title">
      {artista.name}
    </h1>
  </div>
</NodeHiveEntity>
