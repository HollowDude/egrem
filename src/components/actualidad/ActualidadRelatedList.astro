---
import type { NhActualidadItem } from '@/lib/nodehive';
import { useTranslations } from '@/i18n/translations';
import type { Lang } from '@/i18n';
import Badge from '@/components/ui/Badge.astro';
import ActionLink from '@/components/ui/ActionLink.astro';

interface Props {
  items: NhActualidadItem[];
  lang?: Lang;
}

const { items, lang = 'es' } = Astro.props;
const tr = useTranslations(lang);

function itemHref(item: NhActualidadItem): string {
  return item.path || `/actualidad/${item.bundle}/${item.nid}`;
}

function formatDate(d: string): string {
  if (!d) return '';
  const dateObj = new Date(d);
  if (isNaN(dateObj.getTime())) return d;
  return dateObj.toLocaleDateString(lang === 'en' ? 'en-US' : 'es-ES', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
  });
}
---

{
  items.length > 0 && (
    <div class="card card--no-zoom p-6">
      <h3 class="font-display font-bold text-xl text-egrem-black mb-4 border-b border-black/10 pb-3 uppercase tracking-wider">
        {tr('actualidad.detail.related_title')}
      </h3>
      <div class="flex flex-col gap-4">
        {items.slice(0, 4).map((item) => (
          <article class="group">
            <Badge variant="gold" class="mb-2 inline-block">
              {tr(`actualidad.badge.${item.bundle}`)}
            </Badge>
            <h4 class="font-display font-bold text-base text-egrem-black leading-tight m-0 mb-1 group-hover:text-egrem-red transition-colors line-clamp-2">
              <a href={itemHref(item)} class="text-inherit no-underline">
                {item.title}
              </a>
            </h4>
            <p
              class="font-display text-[0.85rem] leading-relaxed m-0 line-clamp-2 mb-2"
              style="color: var(--color-text-secondary);"
            >
              {item.summary}
            </p>
            <div class="flex items-center gap-2 text-egrem-gray text-caption">
              <span class="text-[14px]" style="font-family:'Material Symbols Outlined';">
                calendar_today
              </span>
              <span>{formatDate(item.date)}</span>
            </div>
          </article>
        ))}
      </div>
      <div class="mt-4 pt-3 border-t border-black/10">
        <ActionLink href="/actualidad">{tr('actualidad.detail.back')}</ActionLink>
      </div>
    </div>
  )
}
