---
import type { NhActualidadItem, NhEvento } from '@/lib/nodehive';
import type { Lang } from '@/i18n';
import NodeHiveEntity from '@/components/nodehive/NodeHiveEntity.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import ActualidadDetailHero from '@/components/actualidad/ActualidadDetailHero.astro';
import ActualidadBody from '@/components/actualidad/ActualidadBody.astro';
import ActualidadShareBar from '@/components/actualidad/ActualidadShareBar.astro';
import ActualidadRelatedList from '@/components/actualidad/ActualidadRelatedList.astro';
import ActualidadArtistasRelacionados from '@/components/actualidad/ActualidadArtistasRelacionados.astro';
import ActualidadEventosRelacionados from '@/components/actualidad/ActualidadEventosRelacionados.astro';
import ActualidadFeaturedArtistCard from '@/components/actualidad/ActualidadFeaturedArtistCard.astro';
import EventoMiniCard from '@/components/actualidad/EventoMiniCard.astro';
import ActualidadComments from '@/components/actualidad/ActualidadComments.astro';
import { useTranslations } from '@/i18n/translations';

interface Props {
  item: NhActualidadItem;
  related: NhActualidadItem[];
  eventos?: NhEvento[];
  isAuthenticated?: boolean;
  userName?: string;
  lang: Lang;
}

const { item, related, eventos = [], isAuthenticated = false, userName = '', lang } = Astro.props;
const tr = useTranslations(lang);
const isBlog = item.bundle === 'blog';

function bundleLabel(bundle: string): string {
  const labels: Record<string, string> = {
    noticia: tr('nav.news.news'),
    article: tr('nav.news.articles'),
    blog: tr('nav.news.blog'),
  };
  return labels[bundle] ?? bundle;
}
---

<div class="container-site py-8 md:py-12">
  <Breadcrumb
    items={[
      { label: 'EGREM', href: '/' },
      { label: tr('nav.news'), href: '/actualidad' },
      {
        label: bundleLabel(item.bundle),
        href: `/actualidad#${item.bundle === 'article' ? 'articulos' : item.bundle === 'blog' ? 'blogs' : 'noticias'}`,
      },
      { label: item.title },
    ]}
  />

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mt-8">
    <article class="lg:col-span-8">
      <ActualidadDetailHero
        title={item.title}
        bundle={item.bundle}
        date={item.date}
        author={item.author}
        body={item.body}
        image={item.image}
        variant={isBlog ? 'overlay' : 'plain'}
        lang={lang}
      />

      {
        !isBlog && item.image?.url && (
          <div class="card card--no-zoom overflow-hidden mb-8">
            <img
              src={item.image.url}
              alt={item.image.alt}
              class="w-full aspect-[16/9] object-cover"
              loading="eager"
              decoding="async"
            />
          </div>
        )
      }

      <NodeHiveEntity
        entityType="node"
        bundle={item.bundle}
        id={item.id}
        internalId={item.nid}
        lang={lang}
        tag="div"
        editLabel="Editar contenido"
        editField="body"
      >
        <ActualidadBody body={item.body} tags={item.tags} dropCap={isBlog} hashtagStyle={isBlog} />
      </NodeHiveEntity>

      {
        isBlog && (
          <ActualidadComments
            nodeUuid={item.id}
            nodeNid={item.nid}
            isAuthenticated={isAuthenticated}
            userName={userName}
            lang={lang}
          />
        )
      }

      <div class="mt-10 pt-6 border-t border-black/10">
        <ActualidadShareBar url={Astro.url.href} title={item.title} lang={lang} />
      </div>
    </article>

    <aside class="lg:col-span-4 flex flex-col gap-6">
      {
        isBlog && item.relatedArtists && item.relatedArtists.length > 0 && (
          <ActualidadFeaturedArtistCard artist={item.relatedArtists[0]} lang={lang} />
        )
      }
      {
        !isBlog && (
          <ActualidadArtistasRelacionados artists={item.relatedArtists ?? []} lang={lang} />
        )
      }
      <ActualidadEventosRelacionados events={item.relatedEvents ?? []} lang={lang} />
      {
        isBlog && eventos.length > 0 && (
          <div>
            <h3 class="font-display font-bold text-lg text-egrem-black mb-4 flex items-center gap-2">
              <span class="text-egrem-red" style="font-family:'Material Symbols Outlined';">
                event
              </span>
              {tr('actualidad.detail.related_events_title')}
            </h3>
            <div class="flex flex-col gap-3">
              {eventos.map((ev) => (
                <EventoMiniCard evento={ev} lang={lang} />
              ))}
            </div>
          </div>
        )
      }
      <ActualidadRelatedList items={related} lang={lang} />
    </aside>
  </div>
</div>
