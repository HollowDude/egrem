---
import Badge from '@/components/ui/Badge.astro';
import type { NhActualidadTag } from '@/lib/nodehive';
import { resolveInlineImages } from '@/lib/nodehive';

interface Props {
  body: string;
  tags: NhActualidadTag[];
}

const { body, tags } = Astro.props;

const resolvedBody = resolveInlineImages(
  body,
  import.meta.env.NODEHIVE_BASE_URL?.replace(/\/$/, '') ?? '',
);
---

<div class="egrem-richtext text-body leading-relaxed" style="color: var(--color-egrem-black);">
  {resolvedBody ? <Fragment set:html={resolvedBody} /> : <p class="text-egrem-gray">—</p>}
</div>

{
  tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-10 pt-6 border-t border-black/10">
      {tags.map((tag) => (
        <Badge variant="outline">{tag.label}</Badge>
      ))}
    </div>
  )
}

<style is:global>
  .egrem-richtext p {
    margin-bottom: 1.25rem;
  }

  .egrem-richtext h2 {
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    font-family: var(--font-display);
    font-weight: 700;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    line-height: 1.2;
    color: var(--color-egrem-black);
  }

  .egrem-richtext h3 {
    font-size: clamp(1.1rem, 2vw, 1.375rem);
    font-family: var(--font-display);
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 0.5rem;
    color: var(--color-egrem-black);
  }

  .egrem-richtext blockquote {
    border-left: 4px solid var(--color-egrem-gold);
    padding: 0.75rem 0 0.75rem 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: var(--color-egrem-black);
    opacity: 0.85;
  }

  .egrem-richtext a {
    color: var(--color-brand-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .egrem-richtext a:hover {
    color: var(--color-egrem-red);
  }

  .egrem-richtext ul,
  .egrem-richtext ol {
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
  }

  .egrem-richtext li {
    margin-bottom: 0.25rem;
  }

  .egrem-richtext img {
    max-width: 100%;
    height: auto;
    border-radius: 0.75rem;
    margin: 1.5rem 0;
  }

  .egrem-richtext figure {
    margin: 1.5rem 0;
  }

  .egrem-richtext figcaption {
    font-size: 0.875rem;
    color: var(--color-egrem-gray);
    text-align: center;
    margin-top: 0.5rem;
  }
</style>
