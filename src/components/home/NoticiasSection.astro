---
/**
 * NoticiasSection.astro — "NOVEDADES" — sección de noticias en homepage.
 *
 * Diseño: fondo blanco, 3 cards con imagen, badge de categoría, título, excerpt.
 * Fiel a la maqueta: badge en cuerpo de la card, hover borde rojo.
 *
 * NodeHive: paragraph bundle "_component_home_news"
 */

import SectionHeader from '@/components/ui/SectionHeader.astro';
import Badge from '@/components/ui/Badge.astro';
import ActionLink from '@/components/ui/ActionLink.astro';
import NodeHiveEntity from '@/components/nodehive/NodeHiveEntity.astro';
import type { NhEntityMeta, NhActualidadItem } from '@/lib/nodehive';
import type { Lang } from '@/i18n';
import { useTranslations } from '@/i18n/translations';

interface Props {
  noticias?: NhActualidadItem[];
  nhSectionTitle?: string;
  nhEntity?: NhEntityMeta;
  lang?: Lang;
}

const { noticias, nhSectionTitle, nhEntity, lang = 'es' } = Astro.props;
const tr = useTranslations(lang);

function badgeLabel(item: NhActualidadItem): string {
  return item.tags?.[0]?.label ?? item.bundle;
}

function itemHref(item: NhActualidadItem): string {
  return item.path || `/actualidad/${item.bundle}/${item.nid}`;
}

function placeholders(tr: (key: string) => string): NhActualidadItem[] {
  return [
    {
      id: '1',
      nid: 1,
      bundle: 'noticia',
      title: tr('home.news.card_1_title'),
      summary: tr('home.news.card_1_excerpt'),
      date: '2026-01-15',
      created: '2026-01-15T00:00:00Z',
      body: '',
      author: '',
      patrimonio: false,
      image: null,
      path: '/actualidad/noticias/egrem-60-anos-son',
      tags: [{ slug: 'noticias', label: tr('home.news.card_1_category') }],
    },
    {
      id: '2',
      nid: 2,
      bundle: 'noticia',
      title: tr('home.news.card_2_title'),
      summary: tr('home.news.card_2_excerpt'),
      date: '2026-02-20',
      created: '2026-02-20T00:00:00Z',
      body: '',
      author: '',
      patrimonio: false,
      image: null,
      path: '/actualidad/noticias/gala-premios-musica-2024',
      tags: [{ slug: 'noticias', label: tr('home.news.card_2_category') }],
    },
    {
      id: '3',
      nid: 3,
      bundle: 'noticia',
      title: tr('home.news.card_3_title'),
      summary: tr('home.news.card_3_excerpt'),
      date: '2026-03-10',
      created: '2026-03-10T00:00:00Z',
      body: '',
      author: '',
      patrimonio: false,
      image: null,
      path: '/actualidad/noticias/reediciones-vinilo-platino',
      tags: [{ slug: 'noticias', label: tr('home.news.card_3_category') }],
    },
  ];
}

const items: NhActualidadItem[] = noticias?.length ? noticias : placeholders(tr);
---

<NodeHiveEntity
  entityType="paragraph"
  bundle={nhEntity?.bundle ?? '_component_homepage_novedades'}
  id={nhEntity?.id}
  internalId={nhEntity?.internalId}
  parentId={nhEntity?.parentId}
  lang={lang}
  tag="section"
  class="bg-white section-py"
  editLabel="Editar Novedades"
  editField="field_title"
>
  <div class="container-site">
    <SectionHeader
      title={nhSectionTitle || tr('home.section.news_title')}
      accent="red"
      linkText={tr('home.section.see_more')}
      linkHref="/actualidad"
      theme="light"
      nhField="field_section_title"
    />

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
      {
        items.map((noticia) => (
          <article
            class="card card--hover-red group flex flex-col"
            data-nodehive-entity-type="node"
            data-nodehive-entity-bundle="noticia"
            data-nodehive-entity-id={noticia.id}
          >
            {/* Imagen */}
            <a
              href={itemHref(noticia)}
              class="block overflow-hidden no-underline shrink-0"
              style="height: 16rem;"
            >
              <img
                src={noticia.image?.url}
                alt={noticia.image?.alt ?? ''}
                class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
                decoding="async"
                data-nodehive-field="field_image"
                onerror="this.parentElement.style.background='#eeeeee'"
              />
            </a>

            {/* Cuerpo */}
            <div class="p-6 flex flex-col flex-1">
              <Badge class="mb-4 self-start">{badgeLabel(noticia)}</Badge>

              <h3
                class="font-display font-bold text-egrem-black text-xl leading-tight m-0 mb-2 group-hover:text-egrem-red transition-colors"
                data-nodehive-field="field_title"
              >
                <a href={itemHref(noticia)} class="text-inherit no-underline">
                  {noticia.title}
                </a>
              </h3>

              <p
                class="font-display text-[0.9rem] leading-relaxed m-0 line-clamp-2"
                style="color: var(--color-text-secondary);"
                data-nodehive-field="field_excerpt"
              >
                {noticia.summary}
              </p>

              <ActionLink href={itemHref(noticia)} class="mt-4">
                {tr('home.news.read_more')}
              </ActionLink>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</NodeHiveEntity>
