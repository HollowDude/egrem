---
/**
 * EventosSection.astro — "PRÓXIMOS EVENTOS"
 * Filas horizontales: fecha grande (rojo) + título/lugar + hora + botón Entradas.
 * Acento dorado borde izquierdo en cada fila. Fondo blanco.
 *
 * NodeHive: paragraph bundle "_component_home_eventos"
 */
import SectionHeader from '@/components/ui/SectionHeader.astro';
import Button from '@/components/ui/Button.astro';
import ActionLink from '@/components/ui/ActionLink.astro';
import NodeHiveEntity from '@/components/nodehive/NodeHiveEntity.astro';
import type { NhEntityMeta } from '@/lib/nodehive';
import type { Lang } from '@/i18n';
import { useTranslations } from '@/i18n/translations';
import type { NhEvento } from '@/types/drupal';

function formatDay(dateStr: string): string { return new Date(dateStr).getDate().toString(); }
function formatMonth(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('es', { month: 'short' }).replace('.', '');
}

interface Props {
  items?: NhEvento[];
  nhSectionTitle?: string;
  nhEntity?: NhEntityMeta;
  lang?: Lang;
}

const { items, nhSectionTitle, nhEntity, lang = 'es' } = Astro.props;
const tr = useTranslations(lang);

const eventos: NhEvento[] = items?.length ? items : [
  {
    id: '1',
    title: tr('home.events.card_1_title'),
    venue: tr('home.events.card_1_venue'),
    date: '2026-10-15',
    time: tr('home.events.card_1_time'),
    href: '/eventos/buena-vista-tribute',
  },
  {
    id: '2',
    title: tr('home.events.card_2_title'),
    venue: tr('home.events.card_2_venue'),
    date: '2026-10-22',
    time: tr('home.events.card_2_time'),
    href: '/eventos/haila-mompie-concierto',
  },
  {
    id: '3',
    title: tr('home.events.card_3_title'),
    venue: tr('home.events.card_3_venue'),
    date: '2026-11-05',
    time: tr('home.events.card_3_time'),
    href: '/eventos/festival-jazz-egrem',
  },
];
---

<NodeHiveEntity
  entityType="paragraph"
  bundle={nhEntity?.bundle ?? '_component_homepage_eventos'}
  id={nhEntity?.id}
  internalId={nhEntity?.internalId}
  parentId={nhEntity?.parentId}
  lang={lang}
  tag="section"
  class="section-py bg-white"
  editLabel="Editar Eventos"
  editField="field_title"
>
  <div class="container-site">
    <SectionHeader
      title={nhSectionTitle || tr('home.section.events_title')}
      accent="red"
      linkText={tr('home.section.see_all')}
      linkHref="/eventos"
      theme="light"
      nhField="field_section_title"
    />

    <div class="flex flex-col gap-4">
      {eventos.map((evento) => (
        <div
          class="flex flex-wrap items-center justify-between p-6 bg-white border-l-4 border-egrem-gold shadow-sm hover:shadow-md transition-all rounded-2xl"
          data-nodehive-field="field_eventos"
        >
          {/* Fecha + Título + Lugar */}
          <div class="flex items-center gap-8 sm:gap-10">
            {/* Fecha */}
            <div class="text-center w-20 shrink-0">
              <p class="font-display font-bold text-egrem-red m-0 leading-none" style="font-size: 2.5rem;">
                {formatDay(evento.date)}
              </p>
              <p class="font-display font-bold uppercase m-0" style="font-size: 12px; letter-spacing: 0.05em; color: var(--color-text-secondary);">
                {formatMonth(evento.date)}
              </p>
            </div>

            {/* Info */}
            <div>
              <h3 class="font-display font-bold text-egrem-black uppercase m-0" style="font-size: 1.2rem;">
                {evento.title}
              </h3>
              <p class="font-display uppercase tracking-widest m-0 mt-1" style="font-size: 0.78rem; color: var(--color-text-secondary);">
                {evento.venue}
              </p>
              <ActionLink href={evento.href} class="mt-2">
                {tr('home.section.see_details')}
              </ActionLink>
            </div>
          </div>

          {/* Hora + Botón */}
          <div class="flex items-center gap-8 sm:gap-12 mt-4 sm:mt-0">
            <span class="font-display font-bold" style="font-size: 12px; letter-spacing: 0.05em; color: var(--color-text-secondary);">
              {evento.time}
            </span>
            <Button variant="primary" size="lg" href={evento.href}>
              {tr('home.section.tickets')}
            </Button>
          </div>
        </div>
      ))}
    </div>
  </div>
</NodeHiveEntity>
