---
import SectionHeader from '@/components/ui/SectionHeader.astro';
import NodeHiveEntity from '@/components/nodehive/NodeHiveEntity.astro';
import type { NhEntityMeta } from '@/lib/nodehive';
import type { Lang } from '@/i18n';
import { useTranslations } from '@/i18n/translations';
import type { NhAlbum } from '@/types/drupal';

interface Props {
  items?: NhAlbum[];
  sectionTitle?: string;
  nhEntity?: NhEntityMeta;
  lang?: Lang;
}

const { items, sectionTitle = 'Música Cubana', nhEntity, lang = 'es' } = Astro.props;
const tr = useTranslations(lang);

const tracks: NhAlbum[] = items ?? [
  {
    id: '1',
    cover: { url: '/images/music-placeholder-1.jpg', alt: 'Buena Vista Social Club - Edición Aniversario', filename: 'music-1.jpg' },
    format: 'Vinilo',
    artist: 'Buena Vista Social Club',
    title: 'Edición Aniversario',
    price: '$45.00',
    href: '/catalogo/musica/buena-vista-social-club-aniversario',
  },
  {
    id: '2',
    cover: { url: '/images/music-placeholder-2.jpg', alt: 'Chucho Valdés - Piano Solo', filename: 'music-2.jpg' },
    format: 'CD',
    artist: 'Chucho Valdés',
    title: 'Piano Solo',
    price: '$18.00',
    href: '/catalogo/musica/chucho-valdes-piano-solo',
  },
  {
    id: '3',
    cover: { url: '/images/music-placeholder-3.jpg', alt: 'Omara Portuondo - Lo Mejor', filename: 'music-3.jpg' },
    format: 'Digital',
    artist: 'Omara Portuondo',
    title: 'Lo Mejor de Omara',
    price: '$12.00',
    href: '/catalogo/musica/omara-portuondo-lo-mejor',
  },
  {
    id: '4',
    cover: { url: '/images/music-placeholder-4.jpg', alt: 'Los Van Van - 50 Aniversario', filename: 'music-4.jpg' },
    format: 'CD',
    artist: 'Los Van Van',
    title: '50 Aniversario',
    price: '$22.00',
    href: '/catalogo/musica/los-van-van-50-aniversario',
  },
];
---

<NodeHiveEntity
  entityType="paragraph"
  bundle={nhEntity?.bundle ?? '_component_home_music'}
  id={nhEntity?.id}
  internalId={nhEntity?.internalId}
  parentId={nhEntity?.parentId}
  lang={lang}
  tag="section"
  class="bg-egrem-dark section-py"
  editLabel="Editar Música"
  editField="field_title"
>
  <div class="container-site">

    <SectionHeader
      title={sectionTitle}
      linkText={tr('home.section.see_all')}
      linkHref="/catalogo/musica"
      theme="dark"
      nhField="field_section_title"
    />

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 lg:gap-6">
      {tracks.map((track) => (
        <article
          class="card-dark group"
          data-nodehive-entity-type="node"
          data-nodehive-entity-bundle="producto_musical"
          data-nodehive-entity-id={track.id}
        >
          <a href={track.href} class="block relative aspect-square overflow-hidden bg-egrem-dark-card no-underline">
            <img
              src={track.cover?.url}
              alt={track.cover?.alt ?? track.title}
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              loading="lazy"
              decoding="async"
              data-nodehive-field="field_image"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/70 via-transparent to-transparent opacity-60 group-hover:opacity-80 transition-opacity"
              aria-hidden="true"
            ></div>
            {track.format && (
              <span class="badge bg-egrem-red text-white absolute top-2.5 left-2.5 text-[0.6rem]">
                {track.format}
              </span>
            )}
          </a>

          <div class="p-4 flex flex-col gap-1.5">
            <p
              class="font-display text-[0.7rem] uppercase tracking-widest text-white/40 m-0"
              data-nodehive-field="field_artist"
            >
              {track.artist}
            </p>
            <h3 class="font-display font-bold text-white text-base leading-tight m-0 line-clamp-2" style="font-size: 0.95rem">
              <a
                href={track.href}
                class="text-inherit no-underline hover:text-egrem-gold transition-colors"
                data-nodehive-field="field_title"
              >
                {track.title}
              </a>
            </h3>
            <div class="flex items-center justify-between mt-2">
              {track.price && (
                <span
                  class="font-display font-bold text-egrem-red text-base"
                  data-nodehive-field="field_price"
                >
                  {track.price}
                </span>
              )}
              <a
                href={track.href}
                class="w-7 h-7 flex items-center justify-center bg-egrem-red rounded-full text-white hover:bg-egrem-red-dark transition-colors no-underline"
                aria-label={`${tr('home.section.buy')} ${track.title}`}
              >
                <span class="icon text-[1rem]">add_shopping_cart</span>
              </a>
            </div>
          </div>
        </article>
      ))}
    </div>

  </div>
</NodeHiveEntity>
